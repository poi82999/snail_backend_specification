# 환경 (local / staging / prod)
ENV=local

# --- App ---
APP_NAME=snail-backend
APP_VERSION=0.1.0
LOG_LEVEL=INFO
# allow_credentials=True 이므로 "*"를 쓰지 않고 필요한 로컬 origin을 명시한다.
# JSON 배열 형식으로 유지해야 pydantic-settings가 list[str]로 읽는다.
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://localhost:19006","http://localhost:8081","http://127.0.0.1:3000","http://127.0.0.1:5173","http://127.0.0.1:19006","http://127.0.0.1:8081"]

# --- Database ---
# 로컬: docker-compose 기준
# ?ssl=disable 은 Windows 한글 사용자 경로(예: C:\Users\신민석)에서
# asyncpg가 시스템 SSL cert를 자동 탐색하다 OSError [Errno 42] Illegal byte sequence를
# 일으키는 것을 막기 위함. 로컬 docker는 어차피 평문이라 안전. prod(Cloud SQL Proxy)
# 환경에서는 이 쿼리 파라미터를 빼고 ssl=require 또는 ssl=verify-full을 사용한다.
DATABASE_URL=postgresql+asyncpg://snail:snail@localhost:5432/snail?ssl=disable
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=2

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- JWT ---
JWT_SECRET=change-me-32-chars-minimum-do-not-use
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MIN=60
JWT_REFRESH_EXPIRE_DAYS=30

# --- Apple Sign In ---
APPLE_TEAM_ID=
APPLE_CLIENT_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY_PATH=./secrets/apple_signin.p8

# --- APNs ---
APNS_TEAM_ID=
APNS_KEY_ID=
APNS_PRIVATE_KEY_PATH=./secrets/apns.p8
APNS_BUNDLE_ID=
APNS_USE_SANDBOX=true

# --- OpenAI ---
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small
OPENAI_REQUEST_TIMEOUT_SEC=30
OPENAI_MODEL_VISION=gpt-4o-mini
OPENAI_MODEL_EMBEDDING=text-embedding-3-small
OPENAI_MAX_CONCURRENT=5

# --- GCP ---
GCP_PROJECT_ID=
GCS_BUCKET_DESIGNS=snail-designs-dev
GOOGLE_APPLICATION_CREDENTIALS=./secrets/gcp-sa.json

# --- Kakao Alimtalk (Bizppurio 예시) ---
KAKAO_SENDER_KEY=
BIZPPURIO_USER_ID=
BIZPPURIO_API_KEY=
KAKAO_TEMPLATE_CODES_JSON=

# --- Sentry ---
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
